# --- Telegram ---
# Token from @BotFather (BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Random string you invent yourself. Also passed to setWebhook as secret_token.
# Used to verify incoming requests really come from Telegram
# (checked against the X-Telegram-Bot-Api-Secret-Token header).
TELEGRAM_WEBHOOK_SECRET=

# --- Google ---
# Base64-encoded contents of the service-account JSON key file.
# Create with: base64 -w0 service-account.json   (Linux/Git Bash)
#          or: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json")) | Set-Clipboard   (PowerShell)
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Google Sheet ID, taken from its URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=

# --- Neon (semantic retrieval / RAG - see plans/rag-semantic-retrieval.md) ---
# Pooled Neon Postgres connection string. See scripts/init-neon.md for setup.
DATABASE_URL=

# OpenAI API key, used for embeddings.
OPENAI_API_KEY=

# Tenant id stamped on every row (single-user phase: any fixed slug, e.g.
# your Telegram user id). Also scopes retrieval to this owner.
OWNER_ID=

# Optional - defaults shown.
# EMBEDDING_MODEL=text-embedding-3-small
# SEARCH_TOP_K=20

# Shared secret for api/search.js, checked against the X-Search-Secret header.
SEARCH_SECRET=
