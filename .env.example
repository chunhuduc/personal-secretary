# --- Telegram ---
# Token from @BotFather (BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Random string you invent yourself. Also passed to setWebhook as secret_token.
# Used to verify incoming requests really come from Telegram
# (checked against the X-Telegram-Bot-Api-Secret-Token header).
TELEGRAM_WEBHOOK_SECRET=

# --- Google ---
# Base64-encoded contents of the service-account JSON key file.
# Create with: base64 -w0 service-account.json   (Linux/Git Bash)
#          or: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json")) | Set-Clipboard   (PowerShell)
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Google Sheet ID, taken from its URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=
